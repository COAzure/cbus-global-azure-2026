---
interface Props {
title?: string;
description?: string;
}

const {
title = 'Global Azure Columbus 2026',
description = 'Community conference site for Global Azure Columbus 2026.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width" />
<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
<link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
<meta name="generator" content={Astro.generator} />
<meta name="description" content={description} />
<title>{title}</title>
</head>
<body>
<slot />
</body>
</html>

<style>
:root {
color-scheme: light;
font-family: Inter, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}

html,
body {
margin: 0;
width: 100%;
height: 100%;
min-height: 100%;
background: #f3f7fb;
color: #16324f;
}

body {
line-height: 1.5;
}

*,
*::before,
*::after {
box-sizing: border-box;
}

a {
color: inherit;
}

img {
display: block;
max-width: 100%;
}
</style>
