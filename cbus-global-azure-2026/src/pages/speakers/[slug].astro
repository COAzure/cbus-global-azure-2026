---
import { getCollection, render } from 'astro:content';
import SpeakerPortrait from '../../components/SpeakerPortrait.astro';
import SpeakerSocialLinks from '../../components/SpeakerSocialLinks.astro';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const speakers = await getCollection('speakers');

	return speakers.map((speaker) => ({
		params: { slug: speaker.id.replace(/\.md$/, '') },
		props: { speaker },
	}));
}

const { speaker } = Astro.props;
const { Content } = await render(speaker);
const hasAdditionalContent = (speaker.body ?? '').trim().length > 0;
---

<Layout
title={`${speaker.data.name} | Speakers | Global Azure Columbus 2026`}
description={speaker.data.bio}
>
<main class="page">
<nav class="breadcrumbs" aria-label="Breadcrumb">
<a href={import.meta.env.BASE_URL}>Home</a>
<span aria-hidden="true">/</span>
<a href={`${import.meta.env.BASE_URL}speakers/`}>Speakers</a>
<span aria-hidden="true">/</span>
<strong>{speaker.data.name}</strong>
</nav>

<section class="profile">
<SpeakerPortrait name={speaker.data.name} photo={speaker.data.photo} variant="detail" />
<div class="content">
<p class="eyebrow">Speaker profile</p>
<h1>{speaker.data.name}</h1>
<p class="bio">{speaker.data.bio}</p>
<SpeakerSocialLinks
linkedin={speaker.data.linkedin}
github={speaker.data.github}
blog={speaker.data.blog}
/>
{hasAdditionalContent && (
<section class="details">
<h2>More about {speaker.data.name}</h2>
<div class="markdown">
<Content />
</div>
</section>
)}
</div>
</section>
</main>
</Layout>

<style>
.page {
max-width: 1120px;
margin: 0 auto;
padding: var(--space-11) var(--space-9) var(--space-14);
}

.profile {
display: grid;
gap: var(--space-10);
align-items: start;
margin-top: var(--space-10);
}

.content {
display: grid;
gap: var(--space-8);
padding: var(--space-10);
border-radius: var(--radius-2xl);
background: var(--color-bg-card-alt);
box-shadow: var(--shadow-xl);
}

h1,
h2 {
margin: 0;
}

h1 {
font-size: clamp(2.5rem, 6vw, 4rem);
line-height: 0.98;
}

.bio {
margin: 0;
font-size: var(--font-size-lg);
color: var(--color-text-muted);
}

.details {
display: grid;
gap: var(--space-5);
padding-top: var(--space-3);
border-top: 1px solid var(--color-border-section);
}

.markdown {
color: var(--color-text-muted);
}

.markdown :global(p) {
margin: 0;
}

@media (min-width: 768px) {
.profile {
grid-template-columns: minmax(260px, 360px) minmax(0, 1fr);
}
}
</style>
