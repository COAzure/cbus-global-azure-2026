---
import { getCollection } from 'astro:content';
import SpeakerCard from '../../components/SpeakerCard.astro';
import Layout from '../../layouts/Layout.astro';

const speakers = (await getCollection('speakers'))
	.map((speaker) => ({
		...speaker,
		pageSlug: speaker.id.replace(/\.md$/, ''),
	}))
	.sort((left, right) => left.data.name.localeCompare(right.data.name));
---

<Layout
title="Speakers | Global Azure Columbus 2026"
description="Meet the speaker lineup for Global Azure Columbus 2026."
>
<main class="page">
<header class="hero">
<nav class="breadcrumbs" aria-label="Breadcrumb">
<a href={import.meta.env.BASE_URL}>Home</a>
<span aria-hidden="true">/</span>
<strong>Speakers</strong>
</nav>
<p class="eyebrow">Global Azure Columbus 2026</p>
<h1>Speakers who make Azure practical</h1>
<p class="lede">
Browse the lineup for the Columbus community event and jump into each profile for
links, bios, and speaker details.
</p>
</header>

{speakers.length > 0 ? (
			<section class="grid" aria-label="Speaker listing">
				{speakers.map((speaker) => (
					<SpeakerCard slug={speaker.pageSlug} {...speaker.data} />
				))}
			</section>
) : (
<section class="empty-state">
<h2>Speaker announcements are on the way.</h2>
<p>Please check back soon for the full lineup.</p>
</section>
)}
</main>
</Layout>

<style>
.page {
max-width: 1120px;
margin: 0 auto;
padding: 3rem 1.5rem 4rem;
}

.hero {
display: grid;
gap: 1rem;
padding: 2rem 0 2.5rem;
}

.breadcrumbs {
display: flex;
align-items: center;
gap: 0.5rem;
font-size: 0.95rem;
color: #4f6b88;
}

.breadcrumbs a {
text-decoration: none;
}

.breadcrumbs a:hover,
.breadcrumbs a:focus-visible {
text-decoration: underline;
}

.eyebrow {
margin: 0;
font-size: 0.85rem;
font-weight: 800;
letter-spacing: 0.16em;
text-transform: uppercase;
color: #2563eb;
}

h1 {
margin: 0;
max-width: 12ch;
font-size: clamp(2.8rem, 7vw, 4.5rem);
line-height: 0.95;
}

.lede {
margin: 0;
max-width: 64ch;
font-size: 1.1rem;
color: #35506b;
}

.grid {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
gap: 1.5rem;
}

.empty-state {
padding: 2rem;
border-radius: 24px;
background: rgba(255, 255, 255, 0.92);
box-shadow: 0 28px 55px rgba(15, 23, 42, 0.08);
}

.empty-state h2,
.empty-state p {
margin: 0;
}

.empty-state p {
margin-top: 0.75rem;
color: #35506b;
}
</style>
