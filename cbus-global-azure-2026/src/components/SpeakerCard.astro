---
import SpeakerPortrait from './SpeakerPortrait.astro';
import SpeakerSocialLinks from './SpeakerSocialLinks.astro';

interface Props {
slug: string;
name: string;
bio: string;
photo: string;
linkedin: string;
github: string;
blog?: string;
}

const { slug, name, bio, photo, linkedin, github, blog } = Astro.props;
---

<article class="card">
<a class="portrait-link" href={`${import.meta.env.BASE_URL}speakers/${slug}/`}>
<SpeakerPortrait name={name} photo={photo} variant="card" />
</a>
<div class="content">
<p class="eyebrow">Featured speaker</p>
<h2>
<a href={`${import.meta.env.BASE_URL}speakers/${slug}/`}>{name}</a>
</h2>
<p class="bio">{bio}</p>
<div class="footer">
<SpeakerSocialLinks linkedin={linkedin} github={github} blog={blog} compact />
<a class="details-link" href={`${import.meta.env.BASE_URL}speakers/${slug}/`}>View profile</a>
</div>
</div>
</article>

<style>
.card {
display: grid;
gap: var(--space-9);
}

.portrait-link {
text-decoration: none;
}

.content {
display: grid;
gap: var(--space-6);
}

h2 {
margin: 0;
font-size: clamp(1.45rem, 2vw, 1.75rem);
line-height: var(--line-height-compact);
}

h2 a {
text-decoration: none;
}

.bio {
margin: 0;
color: var(--color-text-muted);
}

.footer {
display: grid;
gap: var(--space-6);
}

.details-link {
justify-self: start;
font-weight: var(--font-weight-bold);
text-decoration: none;
color: var(--color-primary);
}

.details-link:hover,
.details-link:focus-visible,
h2 a:hover,
h2 a:focus-visible {
text-decoration: underline;
}
</style>
