---
interface SpeakerLink {
  name: string;
  slug: string;
}

interface Props {
  title: string;
  timeLabel: string;
  room: string;
  speakers?: SpeakerLink[];
  hasDescription?: boolean;
  id?: string;
}

const { title, timeLabel, room, speakers = [], hasDescription = false, id } = Astro.props;
const hasSpeakers = speakers.length > 0;
---

<article class="session-card" id={id}>
  <div class="meta" aria-label={`Session starts at ${timeLabel}`}>
    <p class="meta-label">Start time</p>
    <p class="time">{timeLabel}</p>
    <p class="room">{room}</p>
  </div>

  <div class="content">
    <h3>{title}</h3>

    {hasDescription && (
      <div class="description">
        <slot name="description" />
      </div>
    )}

    {hasSpeakers && (
      <div class="speakers">
        <p class="speaker-label">{speakers.length === 1 ? 'Speaker' : 'Speakers'}</p>
        <ul class="speaker-list" aria-label={`${title} speakers`}>
          {speakers.map((speaker) => (
            <li>
              <a href={`${import.meta.env.BASE_URL}speakers/${speaker.slug}/`}>{speaker.name}</a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</article>

<style>
  .session-card {
    display: grid;
    gap: var(--space-9);
    padding: var(--space-9);
    border-radius: var(--radius-2xl);
    background: var(--color-bg-card);
    box-shadow: var(--shadow-xl);
  }

  .meta {
    display: grid;
    align-content: start;
    gap: var(--space-2);
    padding: var(--space-8);
    border-radius: var(--radius-lg);
    background: linear-gradient(
      160deg,
      var(--color-bg-gradient-start),
      var(--color-bg-gradient-mid) 60%,
      var(--color-bg-gradient-end)
    );
    color: var(--color-text-heading);
  }

  .meta-label,
  .speaker-label {
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-extrabold);
    letter-spacing: var(--letter-spacing-wider);
    text-transform: uppercase;
    color: var(--color-primary-light);
  }

  .time,
  .room,
  h3 {
    margin: 0;
  }

  .time {
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-extrabold);
    line-height: var(--line-height-snug);
  }

  .room {
    color: var(--color-text-muted);
    font-weight: var(--font-weight-semibold);
  }

  .content {
    display: grid;
    gap: var(--space-6);
  }

  h3 {
    font-size: clamp(1.45rem, 2.5vw, 1.9rem);
    line-height: 1.1;
  }

  .description {
    display: grid;
    gap: var(--space-4);
    color: var(--color-text-muted);
  }

  .description :global(h2),
  .description :global(h3),
  .description :global(h4),
  .description :global(h5),
  .description :global(h6),
  .description :global(p),
  .description :global(ul),
  .description :global(ol) {
    margin: 0;
  }

  .description :global(ul),
  .description :global(ol) {
    padding-left: 1.25rem;
  }

  .description :global(li + li) {
    margin-top: 0.35rem;
  }

  .description :global(a) {
    color: var(--color-primary);
    font-weight: var(--font-weight-semibold);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.14em;
  }

  .description :global(a:hover),
  .description :global(a:focus-visible) {
    color: var(--color-primary-hover);
  }

  .speakers {
    display: grid;
    gap: var(--space-4);
    padding-top: var(--space-1);
    border-top: 1px solid var(--color-border-section);
  }

  .speaker-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .speaker-list a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.65rem 0.95rem;
    border-radius: var(--radius-pill);
    background: var(--color-bg-chip);
    color: var(--color-text-dark);
    font-weight: var(--font-weight-bold);
    text-decoration: none;
    transition:
      transform var(--transition-fast),
      background var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .speaker-list a:hover,
  .speaker-list a:focus-visible {
    background: var(--color-bg-chip-hover);
    box-shadow: var(--shadow-sm);
    transform: translateY(-1px);
  }

  @media (min-width: 720px) {
    .session-card {
      grid-template-columns: minmax(180px, 220px) minmax(0, 1fr);
      align-items: start;
    }
  }
</style>
