---
import SpeakerPortrait from './SpeakerPortrait.astro';
import SpeakerSocialLinks from './SpeakerSocialLinks.astro';

interface SessionSpeaker {
  name: string;
  slug: string;
}

interface AgendaSession {
  id: string;
  title: string;
  timeLabel: string;
  timeMs: number;
  room: string;
  speakers: SessionSpeaker[];
}

interface FeaturedSpeaker {
  slug: string;
  name: string;
  bio: string;
  photo: string;
  linkedin: string;
  github: string;
  blog?: string;
}

interface Props {
  conferenceDate: string;
  dayCount: number;
  sessionCount: number;
  speakerCount: number;
  agendaSessions: AgendaSession[];
  featuredSpeakers: FeaturedSpeaker[];
}

const {
  conferenceDate,
  dayCount,
  sessionCount,
  speakerCount,
  agendaSessions,
  featuredSpeakers,
} = Astro.props;

interface ScheduleRow {
  timeMs: number;
  timeLabel: string;
  title: string;
  room: string;
  speakers: SessionSpeaker[];
  isFixed: boolean;
  id?: string;
}

const FIXED_ROWS: ScheduleRow[] = [
  { timeMs: new Date('2026-04-18T09:30:00-04:00').getTime(), timeLabel: '9:30 AM', title: 'Doors Open', room: 'Lobby', speakers: [], isFixed: true },
  { timeMs: new Date('2026-04-18T12:00:00-04:00').getTime(), timeLabel: '12:00 PM', title: 'Lunch', room: 'Dining Area', speakers: [], isFixed: true },
  { timeMs: new Date('2026-04-18T16:00:00-04:00').getTime(), timeLabel: '4:00 PM', title: 'End of Day', room: '', speakers: [], isFixed: true },
];

const scheduleRows: ScheduleRow[] = [
  ...agendaSessions.map((s) => ({ ...s, isFixed: false })),
  ...FIXED_ROWS,
].sort((a, b) => a.timeMs - b.timeMs);
---

<div class="homepage">
  <header class="hero">
    <nav class="topbar" aria-label="Primary">
      <a class="brand" href={import.meta.env.BASE_URL}>Global Azure Columbus 2026</a>
      <div class="nav-links">
        <a href={`${import.meta.env.BASE_URL}agenda/`}>Agenda</a>
        <a href={`${import.meta.env.BASE_URL}speakers/`}>Speakers</a>
      </div>
    </nav>

    <div class="hero-grid">
      <div class="hero-top">
        <img
          class="event-logo"
          src={`${import.meta.env.BASE_URL}GlobalAzure2026.png`}
          alt="Global Azure 2026"
          loading="eager"
          decoding="async"
        />
        <div class="host-card">
          <img
            class="host-logo"
            src={`${import.meta.env.BASE_URL}azure-cbus-smaller.png`}
            alt="Azure Columbus logo"
            width="422"
            height="452"
            loading="eager"
            decoding="async"
          />
          <div class="host-copy">
            <p class="panel-label">Hosted by</p>
            <p class="host-title">Azure Columbus</p>
            <p>
              Global Azure Columbus is hosted by Azure Columbus, your local Azure user group.
            </p>
          </div>
        </div>
      </div>

      <section class="hero-copy" aria-labelledby="homepage-title">
        <p class="eyebrow">Community conference · {conferenceDate}</p>
        <h1 id="homepage-title">Spend the day with Azure builders who keep cloud work practical.</h1>
        <p class="lede">
          Global Azure Columbus 2026 is a community-led event built for attendees who want clear,
          useful guidance on delivering solutions on the Microsoft Azure platform.
        </p>
        <div class="actions">
          <a class="button primary" href={`${import.meta.env.BASE_URL}agenda/`}>View agenda</a>
          <a class="button secondary" href={`${import.meta.env.BASE_URL}speakers/`}>Meet the speakers</a>
        </div>
      </section>

      <aside class="hero-panel" aria-label="Conference overview">
        <p class="panel-label">At a glance</p>
        <ul class="stats" aria-label="Conference stats">
          <li>
            <strong>{dayCount}</strong>
            <span>{dayCount === 1 ? 'day' : 'days'}</span>
          </li>
          <li>
            <strong>{sessionCount}</strong>
            <span>{sessionCount === 1 ? 'session' : 'sessions'}</span>
          </li>
          <li>
            <strong>{speakerCount}</strong>
            <span>{speakerCount === 1 ? 'speaker' : 'speakers'}</span>
          </li>
        </ul>
        <p class="panel-copy">
          Explore practical sessions designed to help teams build and operate Azure solutions with confidence.
        </p>
        <a class="panel-link" href={`${import.meta.env.BASE_URL}agenda/`}>Plan your conference day</a>
      </aside>
    </div>
  </header>

  <main class="content">
    <section class="section" aria-labelledby="schedule-title">
      <div class="section-heading">
        <p class="eyebrow">Conference schedule</p>
        <h2 id="schedule-title">Schedule at a glance</h2>
        <p>
          Here's how the day unfolds. See the <a class="inline-link" href={`${import.meta.env.BASE_URL}agenda/`}>full agenda</a> for session details and speaker bios.
        </p>
      </div>

      <div class="schedule-wrap">
        <table class="schedule-table" aria-label="Conference day schedule">
          <thead>
            <tr>
              <th scope="col">Time</th>
              <th scope="col">Session</th>
              <th scope="col">Room</th>
            </tr>
          </thead>
          <tbody>
            {scheduleRows.map((row) => (
              <tr class={row.isFixed ? 'row-fixed' : 'row-session'}>
                <td class="col-time">{row.timeLabel}</td>
                <td class="col-title">
                  {!row.isFixed && row.id ? (
                    <a class="row-title session-link" href={`${import.meta.env.BASE_URL}agenda/#${row.id}`}>{row.title}</a>
                  ) : (
                    <span class="row-title">{row.title}</span>
                  )}
                  {!row.isFixed && row.speakers.length > 0 && (
                    <ul class="speaker-chips" aria-label={`${row.title} speakers`}>
                      {row.speakers.map((speaker) => (
                        <li>
                          <a href={`${import.meta.env.BASE_URL}speakers/${speaker.slug}/`}>{speaker.name}</a>
                        </li>
                      ))}
                    </ul>
                  )}
                </td>
                <td class="col-room">{row.room}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <a class="text-link" href={`${import.meta.env.BASE_URL}agenda/`}>See the full agenda</a>
    </section>

    <section class="section" aria-labelledby="featured-speakers-title">
      <div class="section-heading">
        <p class="eyebrow">Speaker lineup</p>
        <h2 id="featured-speakers-title">Meet the voices behind the sessions</h2>
        <p>
          Get familiar with the speakers, follow their work, and head into the event knowing where
          to continue the conversation.
        </p>
      </div>

      {featuredSpeakers.length > 0 ? (
        <div class="speaker-grid">
          {featuredSpeakers.map((speaker) => (
            <article class="speaker-card">
              <a class="speaker-portrait-link" href={`${import.meta.env.BASE_URL}speakers/${speaker.slug}/`}>
                <SpeakerPortrait name={speaker.name} photo={speaker.photo} variant="card" />
              </a>
              <div class="speaker-content">
                <p class="panel-label">Featured speaker</p>
                <h3>
                  <a href={`${import.meta.env.BASE_URL}speakers/${speaker.slug}/`}>{speaker.name}</a>
                </h3>
                <p>{speaker.bio}</p>
                <SpeakerSocialLinks
                  linkedin={speaker.linkedin}
                  github={speaker.github}
                  blog={speaker.blog}
                  compact
                />
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <h3>Speaker announcements are coming soon.</h3>
          <p>Please check back soon for the full conference lineup.</p>
        </div>
      )}

      <a class="text-link" href={`${import.meta.env.BASE_URL}speakers/`}>Browse all speakers</a>
    </section>

    <section class="cta-panel" aria-labelledby="homepage-cta-title">
      <div>
        <p class="eyebrow">Ready to plan?</p>
        <h2 id="homepage-cta-title">Pick your sessions and start the day prepared.</h2>
      </div>
      <p>
        The homepage gives you the overview; the agenda and speakers pages help you decide where to
        spend your time and who you want to learn from.
      </p>
      <div class="actions compact">
        <a class="button primary" href={`${import.meta.env.BASE_URL}agenda/`}>Go to agenda</a>
        <a class="button secondary" href={`${import.meta.env.BASE_URL}speakers/`}>Go to speakers</a>
      </div>
    </section>
  </main>
</div>

<style>
  .homepage {
    max-width: 1120px;
    margin: 0 auto;
    padding: 1.5rem 1.5rem 4rem;
  }

  .topbar,
  .hero-copy,
  .host-card,
  .host-copy,
  .hero-panel,
  .section,
  .section-heading,
  .speaker-card,
  .cta-panel {
    display: grid;
    gap: 1rem;
  }

  .speaker-content {
    display: grid;
    gap: 1rem;
    min-width: 0;
    overflow: hidden;
  }

  .speaker-content h3,
  .speaker-content h3 a {
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .hero-top {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero {
    display: grid;
    gap: 2rem;
    padding: 1rem 0 2.5rem;
  }

  .topbar {
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 1rem;
  }

  .brand,
  .nav-links a,
  .text-link,
  .panel-link,
  .speaker-content h3 a {
    text-decoration: none;
  }

  .brand {
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .nav-links a,
  .panel-link,
  .text-link {
    font-weight: 700;
    color: #1d4ed8;
  }

  .nav-links a:hover,
  .nav-links a:focus-visible,
  .text-link:hover,
  .text-link:focus-visible,
  .panel-link:hover,
  .panel-link:focus-visible,
  .speaker-content h3 a:hover,
  .speaker-content h3 a:focus-visible {
    text-decoration: underline;
  }

  .hero-grid {
    display: grid;
    gap: 1.5rem;
  }

  .eyebrow,
  .panel-label {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #2563eb;
  }

  h1,
  h2,
  h3,
  .lede,
  .section-heading p,
  .panel-copy,
  .session-content p,
  .speaker-content p,
  .session-time,
  .session-room,
  .cta-panel > p {
    margin: 0;
  }

  .event-logo {
    width: clamp(200px, 55%, 360px);
    height: auto;
    object-fit: contain;
    display: block;
    border-radius: 24px;
  }

  h1 {
    max-width: 40ch;
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    line-height: 1.4;
    font-weight: 600;
    color: #35506b;
  }

  h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1;
  }

  h3 {
    font-size: clamp(1.4rem, 2vw, 1.8rem);
    line-height: 1.1;
  }

  .lede,
  .section-heading p,
  .panel-copy,
  .session-content p,
  .speaker-content p,
  .session-room,
  .cta-panel > p {
    color: #35506b;
  }

  .lede {
    max-width: 62ch;
    font-size: 1.1rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.8rem 1.3rem;
    border-radius: 999px;
    font-weight: 800;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      background 0.2s ease,
      color 0.2s ease;
  }

  .button:hover,
  .button:focus-visible {
    transform: translateY(-1px);
  }

  .button.primary {
    background: linear-gradient(135deg, #1d4ed8, #2563eb 55%, #38bdf8);
    color: #ffffff;
    box-shadow: 0 18px 35px rgba(37, 99, 235, 0.28);
  }

  .button.secondary {
    background: rgba(255, 255, 255, 0.88);
    color: #16324f;
    box-shadow: inset 0 0 0 1px #c7d8ec;
  }

  .host-card {
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: 1.1rem;
    padding: 1rem 1.1rem;
    border-radius: 24px;
    background: #ffffff;
  }

  .host-copy {
    gap: 0.35rem;
    align-content: start;
  }

  .host-logo {
    width: clamp(76px, 15vw, 110px);
    height: auto;
    object-fit: contain;
  }

  .host-title,
  .host-copy p {
    margin: 0;
  }

  .host-title {
    font-size: 1.2rem;
    font-weight: 800;
    color: #16324f;
  }

  .host-copy p:last-child {
    color: #35506b;
  }

  .hero-panel,
  .speaker-card,
  .cta-panel,
  .empty-state,
  .schedule-wrap {
    padding: 1.5rem;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 28px 55px rgba(15, 23, 42, 0.08);
  }

  .stats,
  .speaker-chips {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .stats li {
    display: grid;
    gap: 0.35rem;
    padding: 0.85rem;
    border-radius: 20px;
    background: linear-gradient(160deg, #dbeafe, #eff6ff 60%, #ffffff);
  }

  .stats strong {
    font-size: 1.6rem;
    line-height: 1;
  }

  .stats span {
    color: #35506b;
    font-weight: 600;
  }

  .content {
    display: grid;
    gap: 2.5rem;
  }

  .section {
    gap: 1.5rem;
  }

  .speaker-grid {
    display: grid;
    gap: 1.25rem;
  }

  /* ── Schedule table ─────────────────────────────────────────── */

  .schedule-wrap {
    overflow-x: auto;
    padding: 0;
  }

  .schedule-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .schedule-table thead {
    border-bottom: 2px solid #dbeafe;
  }

  .schedule-table th {
    padding: 0.85rem 1.1rem;
    text-align: left;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #2563eb;
  }

  .schedule-table tbody tr {
    border-bottom: 1px solid #e8f0f8;
  }

  .schedule-table tbody tr:last-child {
    border-bottom: none;
  }

  .schedule-table td {
    padding: 0.9rem 1.1rem;
    vertical-align: top;
  }

  .row-session .col-time {
    font-weight: 800;
    color: #16324f;
    white-space: nowrap;
  }

  .row-session .row-title {
    font-weight: 700;
    color: #0f2942;
  }

  a.row-title.session-link {
    color: #1d4ed8;
    text-decoration: none;
  }

  a.row-title.session-link:hover,
  a.row-title.session-link:focus-visible {
    text-decoration: underline;
  }

  .row-fixed {
    background: #f8fafc;
  }

  .row-fixed .col-time {
    font-weight: 600;
    color: #64748b;
    white-space: nowrap;
  }

  .row-fixed .row-title {
    color: #64748b;
    font-weight: 600;
  }

  .row-fixed .col-room {
    color: #94a3b8;
  }

  .col-room {
    color: #35506b;
    white-space: nowrap;
  }

  .inline-link {
    color: #1d4ed8;
    font-weight: 700;
  }

  /* ── Speaker chips (inside table) ───────────────────────────── */
  .speaker-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-top: 0.25rem;
  }

  .speaker-chips a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.65rem 0.95rem;
    border-radius: 999px;
    background: #e2ecf8;
    color: #0f2942;
    font-weight: 700;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      background 0.2s ease,
      box-shadow 0.2s ease;
  }

  .speaker-chips a:hover,
  .speaker-chips a:focus-visible {
    background: #c9def5;
    box-shadow: 0 14px 30px rgba(59, 130, 246, 0.18);
    transform: translateY(-1px);
  }

  .speaker-card {
    align-content: start;
  }

  .speaker-portrait-link {
    text-decoration: none;
  }

  .empty-state h3,
  .empty-state p {
    margin: 0;
  }

  .empty-state p {
    color: #35506b;
  }

  @media (min-width: 720px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.25fr) minmax(300px, 0.75fr);
      align-items: start;
    }

    .hero-top {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: stretch;
      gap: 2rem;
    }

    .hero-top .event-logo {
      flex: 0 0 auto;
      height: 100%;
      object-fit: contain;
      align-self: stretch;
    }

    .hero-top .host-card {
      flex: 1 1 auto;
      display: flex;
      align-items: center;
    }

    .speaker-grid {
      grid-template-columns: repeat(auto-fit, minmax(420px, 1fr));
    }

    .speaker-card {
      grid-template-columns: minmax(140px, 180px) minmax(0, 1fr);
    }

    .cta-panel {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) auto;
      align-items: center;
    }
  }

  @media (max-width: 719px) {
    .homepage {
      padding-top: 1rem;
    }

    .topbar {
      grid-template-columns: 1fr;
    }

    .stats {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .host-card {
      grid-template-columns: 1fr;
      justify-items: start;
    }
  }

  @media (max-width: 520px) {
    .homepage {
      padding-inline: 1rem;
    }

    .stats {
      grid-template-columns: 1fr;
    }

    .actions.compact {
      width: 100%;
    }

    .actions.compact .button {
      flex: 1 1 100%;
    }
  }
</style>
