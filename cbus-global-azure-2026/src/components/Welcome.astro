---
import SpeakerPortrait from './SpeakerPortrait.astro';
import SpeakerSocialLinks from './SpeakerSocialLinks.astro';

interface SessionSpeaker {
  name: string;
  slug: string;
}

interface AgendaSession {
  id: string;
  title: string;
  timeLabel: string;
  timeMs: number;
  room: string;
  speakers: SessionSpeaker[];
}

interface FeaturedSpeaker {
  slug: string;
  name: string;
  bio: string;
  photo: string;
  linkedin: string;
  github: string;
  blog?: string;
}

interface Props {
  conferenceDate: string;
  dayCount: number;
  sessionCount: number;
  speakerCount: number;
  agendaSessions: AgendaSession[];
  featuredSpeakers: FeaturedSpeaker[];
}

const {
  conferenceDate,
  dayCount,
  sessionCount,
  speakerCount,
  agendaSessions,
  featuredSpeakers,
} = Astro.props;

interface ScheduleRow {
  timeMs: number;
  timeLabel: string;
  title: string;
  room: string;
  speakers: SessionSpeaker[];
  isFixed: boolean;
  id?: string;
}

const FIXED_ROWS: ScheduleRow[] = [
  { timeMs: new Date('2026-04-18T09:30:00-04:00').getTime(), timeLabel: '9:30 AM', title: 'Doors Open / Registration / Networking', room: 'Lobby', speakers: [], isFixed: true },
  { timeMs: new Date('2026-04-18T10:00:00-04:00').getTime(), timeLabel: '10:00 AM', title: 'Opening Remarks', room: 'Main Stage', speakers: [], isFixed: true },
  { timeMs: new Date('2026-04-18T10:50:00-04:00').getTime(), timeLabel: '10:50 AM', title: 'Break', room: '', speakers: [], isFixed: true },
  { timeMs: new Date('2026-04-18T11:40:00-04:00').getTime(), timeLabel: '11:40 AM', title: 'Break', room: '', speakers: [], isFixed: true },
  { timeMs: new Date('2026-04-18T12:30:00-04:00').getTime(), timeLabel: '12:30 PM', title: 'Lunch', room: 'Dining Area', speakers: [], isFixed: true },
  { timeMs: new Date('2026-04-18T13:40:00-04:00').getTime(), timeLabel: '1:40 PM', title: 'Break', room: '', speakers: [], isFixed: true },
  { timeMs: new Date('2026-04-18T14:30:00-04:00').getTime(), timeLabel: '2:30 PM', title: 'Break', room: '', speakers: [], isFixed: true },
  { timeMs: new Date('2026-04-18T15:20:00-04:00').getTime(), timeLabel: '3:20 PM', title: 'Panel Discussion / Buffer', room: 'Main Stage', speakers: [], isFixed: true },
  { timeMs: new Date('2026-04-18T15:50:00-04:00').getTime(), timeLabel: '3:50 PM', title: 'Closing Remarks', room: 'Main Stage', speakers: [], isFixed: true },
  { timeMs: new Date('2026-04-18T16:00:00-04:00').getTime(), timeLabel: '4:00 PM', title: 'Go Home', room: '', speakers: [], isFixed: true },
];

const scheduleRows: ScheduleRow[] = [
  ...agendaSessions.map((s) => ({ ...s, isFixed: false })),
  ...FIXED_ROWS,
].sort((a, b) => a.timeMs - b.timeMs);
---

<div class="homepage">
  <header class="hero">
    <nav class="topbar" aria-label="Primary">
      <a class="brand" href={import.meta.env.BASE_URL}>Global Azure Columbus 2026</a>
      <div class="nav-links">
        <a href={`${import.meta.env.BASE_URL}agenda/`}>Agenda</a>
        <a href={`${import.meta.env.BASE_URL}speakers/`}>Speakers</a>
      </div>
    </nav>

    <div class="hero-grid">
      <div class="hero-top">
        <img
          class="event-logo"
          src={`${import.meta.env.BASE_URL}GlobalAzure2026.png`}
          alt="Global Azure 2026"
          loading="eager"
          decoding="async"
        />
        <div class="host-card">
          <img
            class="host-logo"
            src={`${import.meta.env.BASE_URL}azure-cbus-smaller.png`}
            alt="Azure Columbus logo"
            width="422"
            height="452"
            loading="eager"
            decoding="async"
          />
          <div class="host-copy">
            <p class="panel-label">Hosted by</p>
            <p class="host-title">Azure Columbus</p>
            <p>
              Global Azure Columbus is hosted by <a href="https://www.meetup.com/central-ohio-azure/" target="_blank" rel="noopener noreferrer">Azure Columbus</a>, your local Azure user group.
            </p>
            <p>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="vertical-align: middle; margin-right: 0.3em;"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/></svg>Join the <a href="https://discord.gg/w2F9KS3HCs" target="_blank" rel="noopener noreferrer">Azure Columbus community on Discord</a>.
            </p>
          </div>
        </div>
      </div>

      <section class="hero-copy" aria-labelledby="homepage-title">
        <p class="eyebrow">Community conference · {conferenceDate}</p>
        <h1 id="homepage-title">Spend the day with Azure builders who keep cloud work practical.</h1>
        <p class="lede">
          Global Azure Columbus 2026 is a community-led event built for attendees who want clear,
          useful guidance on delivering solutions on the Microsoft Azure platform.
        </p>
        <div class="actions">
          <a class="button primary" href="https://www.meetup.com/central-ohio-azure/events/313484939/" target="_blank" rel="noopener noreferrer">Register</a>
          <a class="button secondary" href={`${import.meta.env.BASE_URL}agenda/`}>View agenda</a>
          <a class="button secondary" href={`${import.meta.env.BASE_URL}speakers/`}>Meet the speakers</a>
        </div>
      </section>

      <aside class="hero-panel" aria-label="Conference overview">
        <p class="panel-label">At a glance</p>
        <ul class="stats" aria-label="Conference stats">
          <li>
            <strong>{dayCount}</strong>
            <span>{dayCount === 1 ? 'day' : 'days'}</span>
          </li>
          <li>
            <strong>{sessionCount}</strong>
            <span>{sessionCount === 1 ? 'session' : 'sessions'}</span>
          </li>
          <li>
            <strong>{speakerCount}</strong>
            <span>{speakerCount === 1 ? 'speaker' : 'speakers'}</span>
          </li>
        </ul>
        <p class="panel-copy">
          Explore practical sessions designed to help teams build and operate Azure solutions with confidence.
        </p>
        <a class="panel-link" href={`${import.meta.env.BASE_URL}agenda/`}>Plan your conference day</a>
      </aside>
    </div>
  </header>

  <main class="content">
    <section class="section" aria-labelledby="schedule-title">
      <div class="section-heading">
        <p class="eyebrow">Conference schedule</p>
        <h2 id="schedule-title">Schedule at a glance</h2>
        <p>
          Here's how the day unfolds. See the <a class="inline-link" href={`${import.meta.env.BASE_URL}agenda/`}>full agenda</a> for session details and speaker bios.
        </p>
      </div>

      <div class="schedule-wrap">
        <table class="schedule-table" aria-label="Conference day schedule">
          <thead>
            <tr>
              <th scope="col">Time</th>
              <th scope="col">Session</th>
              <th scope="col">Room</th>
            </tr>
          </thead>
          <tbody>
            {scheduleRows.map((row) => (
              <tr class={row.isFixed ? 'row-fixed' : 'row-session'}>
                <td class="col-time">{row.timeLabel}</td>
                <td class="col-title">
                  {!row.isFixed && row.id ? (
                    <a class="row-title session-link" href={`${import.meta.env.BASE_URL}agenda/#${row.id}`}>{row.title}</a>
                  ) : (
                    <span class="row-title">{row.title}</span>
                  )}
                  {!row.isFixed && row.speakers.length > 0 && (
                    <ul class="speaker-chips" aria-label={`${row.title} speakers`}>
                      {row.speakers.map((speaker) => (
                        <li>
                          <a href={`${import.meta.env.BASE_URL}speakers/${speaker.slug}/`}>{speaker.name}</a>
                        </li>
                      ))}
                    </ul>
                  )}
                </td>
                <td class="col-room">{row.room || '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <a class="text-link" href={`${import.meta.env.BASE_URL}agenda/`}>See the full agenda</a>
    </section>

    <section class="section" aria-labelledby="featured-speakers-title">
      <div class="section-heading">
        <p class="eyebrow">Speaker lineup</p>
        <h2 id="featured-speakers-title">Meet the voices behind the sessions</h2>
        <p>
          Get familiar with the speakers, follow their work, and head into the event knowing where
          to continue the conversation.
        </p>
      </div>

      {featuredSpeakers.length > 0 ? (
        <div class="speaker-grid">
          {featuredSpeakers.map((speaker) => (
            <article class="speaker-card">
              <a class="speaker-portrait-link" href={`${import.meta.env.BASE_URL}speakers/${speaker.slug}/`}>
                <SpeakerPortrait name={speaker.name} photo={speaker.photo} variant="card" />
              </a>
              <div class="speaker-content">
                <p class="panel-label">Featured speaker</p>
                <h3>
                  <a href={`${import.meta.env.BASE_URL}speakers/${speaker.slug}/`}>{speaker.name}</a>
                </h3>
                <p class="speaker-bio">{speaker.bio}</p>
                <SpeakerSocialLinks
                  linkedin={speaker.linkedin}
                  github={speaker.github}
                  blog={speaker.blog}
                  compact
                />
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <h3>Speaker announcements are coming soon.</h3>
          <p>Please check back soon for the full conference lineup.</p>
        </div>
      )}

      <a class="text-link" href={`${import.meta.env.BASE_URL}speakers/`}>Browse all speakers</a>
    </section>

    <section class="cta-panel" aria-labelledby="homepage-cta-title">
      <div>
        <p class="eyebrow">Ready to plan?</p>
        <h2 id="homepage-cta-title">Pick your sessions and start the day prepared.</h2>
      </div>
      <p>
        The homepage gives you the overview; the agenda and speakers pages help you decide where to
        spend your time and who you want to learn from.
      </p>
      <div class="actions compact">
        <a class="button primary" href={`${import.meta.env.BASE_URL}agenda/`}>Go to agenda</a>
        <a class="button secondary" href={`${import.meta.env.BASE_URL}speakers/`}>Go to speakers</a>
      </div>
    </section>
  </main>
</div>

<style>
  .homepage {
    max-width: 1120px;
    margin: 0 auto;
    padding: var(--space-9) var(--space-9) var(--space-14);
  }

  .topbar,
  .hero-copy,
  .host-card,
  .host-copy,
  .hero-panel,
  .section,
  .section-heading,
  .speaker-card,
  .cta-panel {
    display: grid;
    gap: var(--space-6);
  }

  .speaker-content {
    display: grid;
    gap: var(--space-6);
    min-width: 0;
    overflow: hidden;
  }

  .speaker-content h3,
  .speaker-content h3 a {
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .hero-top {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .hero {
    display: grid;
    gap: var(--space-10);
    padding: var(--space-6) 0 var(--space-11);
  }

  .topbar {
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--space-6);
  }

  .brand,
  .nav-links a,
  .speaker-content h3 a {
    text-decoration: none;
  }

  .brand {
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-extrabold);
    letter-spacing: var(--letter-spacing-tight);
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
  }

  .nav-links a {
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
  }

  .nav-links a:hover,
  .nav-links a:focus-visible,
  .speaker-content h3 a:hover,
  .speaker-content h3 a:focus-visible {
    text-decoration: underline;
  }

  .hero-grid {
    display: grid;
    gap: var(--space-9);
  }

  h1,
  h2,
  h3,
  .lede,
  .section-heading p,
  .panel-copy,
  .session-content p,
  .speaker-content p,
  .session-time,
  .session-room,
  .cta-panel > p {
    margin: 0;
  }

  .event-logo {
    width: clamp(200px, 55%, 360px);
    height: auto;
    object-fit: contain;
    display: block;
    border-radius: var(--radius-xl);
  }

  h1 {
    max-width: 40ch;
    font-size: clamp(var(--font-size-h1-min), 2vw, var(--font-size-h1-max));
    line-height: var(--line-height-normal);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-heading);
  }

  h2 {
    font-size: clamp(var(--font-size-h2-min), 4vw, var(--font-size-h2-max));
    line-height: var(--line-height-snug);
  }

  h3 {
    font-size: clamp(var(--font-size-h3-min), 2vw, var(--font-size-h3-max));
    line-height: var(--line-height-compact);
  }

  .lede,
  .section-heading p,
  .panel-copy,
  .session-content p,
  .speaker-content p,
  .session-room,
  .cta-panel > p {
    color: var(--color-text-muted);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
    margin-top: var(--space-3);
  }

  .host-card {
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: var(--space-7);
    padding: var(--space-6) var(--space-7);
    border-radius: var(--radius-xl);
    background: var(--color-bg-card-solid);
  }

  .host-copy {
    gap: var(--space-2);
    align-content: start;
  }

  .host-logo {
    width: clamp(76px, 15vw, 110px);
    height: auto;
    object-fit: contain;
  }

  .host-title,
  .host-copy p {
    margin: 0;
  }

  .host-title {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-extrabold);
    color: var(--color-text-heading);
  }

  .host-copy p:last-child {
    color: var(--color-text-body);
  }

  .hero-panel,
  .speaker-card,
  .cta-panel,
  .schedule-wrap {
    padding: var(--space-9);
    border-radius: var(--radius-2xl);
    background: var(--color-bg-card);
    box-shadow: var(--shadow-xl);
  }

  .stats,
  .speaker-chips {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .stats li {
    display: grid;
    gap: var(--space-2);
    padding: var(--space-5);
    border-radius: var(--radius-md);
    background: linear-gradient(
      160deg,
      var(--color-bg-gradient-start),
      var(--color-bg-gradient-mid) 60%,
      var(--color-bg-gradient-end)
    );
  }

  .stats strong {
    font-size: var(--font-size-4xl);
    line-height: var(--line-height-snug);
    color: var(--color-primary);
  }

  .stats span {
    color: var(--color-text-muted);
    font-weight: var(--font-weight-semibold);
  }

  .content {
    display: grid;
    gap: var(--space-11);
  }

  .section {
    gap: var(--space-9);
  }

  .speaker-grid {
    display: grid;
    gap: var(--space-8);
  }

  /* ── Schedule table ─────────────────────────────────────────── */

  .schedule-wrap {
    overflow-x: auto;
    padding: 0;
  }

  .schedule-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--font-size-base);
  }

  .schedule-table thead {
    border-bottom: 2px solid var(--color-border-header);
  }

  .schedule-table th {
    padding: var(--space-5) var(--space-7);
    text-align: left;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-extrabold);
    letter-spacing: var(--letter-spacing-wider);
    text-transform: uppercase;
    color: var(--color-primary-light);
  }

  .schedule-table tbody tr {
    border-bottom: 1px solid var(--color-border-light);
  }

  .schedule-table tbody tr:last-child {
    border-bottom: none;
  }

  .schedule-table td {
    padding: var(--space-6) var(--space-8);
    vertical-align: top;
  }

  .row-session .col-time {
    font-weight: var(--font-weight-extrabold);
    color: var(--color-text-heading);
    white-space: nowrap;
  }

  .row-session .row-title {
    font-weight: var(--font-weight-bold);
    color: var(--color-text-dark);
  }

  a.row-title.session-link {
    color: var(--color-primary);
    text-decoration: none;
  }

  a.row-title.session-link:hover,
  a.row-title.session-link:focus-visible {
    text-decoration: underline;
  }

  .row-fixed {
    background: var(--color-bg-fixed-row);
  }

  .row-fixed .col-time {
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-faded);
    white-space: nowrap;
  }

  .row-fixed .row-title {
    color: var(--color-text-faded);
    font-weight: var(--font-weight-semibold);
  }

  .row-fixed .col-room {
    color: var(--color-text-disabled);
  }

  .col-room {
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  /* ── Speaker chips (inside table) ───────────────────────────── */
  .speaker-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    padding-top: var(--space-1);
  }

  .speaker-chips a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.65rem 0.95rem;
    border-radius: var(--radius-pill);
    background: var(--color-bg-chip);
    color: var(--color-text-dark);
    font-weight: var(--font-weight-bold);
    text-decoration: none;
    transition:
      transform var(--transition-fast),
      background var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .speaker-chips a:hover,
  .speaker-chips a:focus-visible {
    background: var(--color-bg-chip-hover);
    box-shadow: var(--shadow-sm);
    transform: translateY(-1px);
  }

  .speaker-card {
    align-content: start;
  }

  .speaker-bio {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    line-clamp: 3;
    box-orient: vertical;
    overflow: hidden;
  }

  .speaker-portrait-link {
    text-decoration: none;
  }

  /* ── Speaker card shadow ────────────────────────────────────── */

  .speaker-card {
    box-shadow: var(--shadow-lg);
  }

  @media (min-width: 720px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.25fr) minmax(300px, 0.75fr);
      align-items: start;
    }

    .hero-top {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: stretch;
      gap: var(--space-10);
    }

    .hero-top .event-logo {
      flex: 0 0 auto;
      height: 100%;
      object-fit: contain;
      align-self: stretch;
    }

    .hero-top .host-card {
      flex: 1 1 auto;
      display: flex;
      align-items: center;
    }

    .speaker-grid {
      grid-template-columns: repeat(auto-fit, minmax(420px, 1fr));
    }

    .speaker-card {
      grid-template-columns: minmax(140px, 180px) minmax(0, 1fr);
    }

    .cta-panel {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) auto;
      align-items: center;
    }

    .cta-panel .actions {
      align-self: start;
    }
  }

  @media (max-width: 719px) {
    .homepage {
      padding-top: var(--space-6);
    }

    .topbar {
      grid-template-columns: 1fr;
    }

    .stats {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .host-card {
      grid-template-columns: 1fr;
      justify-items: start;
    }
  }

  @media (max-width: 520px) {
    .homepage {
      padding-inline: var(--space-6);
    }

    .stats {
      grid-template-columns: 1fr;
    }

    .actions.compact {
      width: 100%;
    }

    .actions.compact .button {
      flex: 1 1 100%;
    }

    .schedule-table .col-room,
    .schedule-table th:last-child {
      display: none;
    }
  }
</style>
